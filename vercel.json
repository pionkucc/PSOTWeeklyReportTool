{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "pip install -r requirements.txt",
  "routes": [
    {
      "src": "/",
      "dest": "/api/index.py"
    },
    {
      "src": "/sync",
      "dest": "/api/sync.py"
    },
    {
      "src": "/upload",
      "dest": "/api/index.py"
    },
    {
      "src": "/api/data",
      "dest": "/api/index.py"
    },
    {
      "src": "/api/status",
      "dest": "/api/index.py"
    }
  ]
}